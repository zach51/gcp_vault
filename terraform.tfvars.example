project_id   = "zachbeelercloud-dev"
region       = "us-central1"
zone         = "us-central1-a"
name_prefix  = "vault-lab"

# Replace with your trusted public IP ranges.
admin_cidrs = [
  "203.0.113.10/32"
]

# Optional sizing and scaling knobs
gke_node_machine_type = "e2-medium"
gke_node_count        = 1
gke_enable_autoscaling = false
gke_min_node_count    = 1
gke_max_node_count    = 1
gke_preemptible_nodes = true
gke_node_disk_size_gb = 30
gke_node_disk_type    = "pd-standard"

# Automatic off-hours scale-to-zero (Vault unavailable while scaled down)
enable_scheduled_scale_down = true
scheduled_scale_down_cron   = "0 2 * * *"
scheduled_scale_up_cron     = "0 7 * * *"
scheduled_scale_timezone    = "America/Chicago"
scheduled_daytime_node_count = 1

# Optional: pin a chart version, otherwise Terraform uses latest available
# vault_helm_chart_version = "0.28.0"

vault_version      = "1.17.5"
vault_storage_size = "10Gi"
